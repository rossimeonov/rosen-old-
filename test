    <style>
        :root {
            --primary-blue: #243a96;
            --secondary-blue: #2f47b8;
            --deep-blue: #15205d;
            --navy: #07153b;
            --accent-light: #e9efff;
            --white: #ffffff;
            --text-soft: rgba(255,255,255,0.82);
            --text-dark: #1e2a4f;
            --shadow: 0 18px 45px rgba(7, 21, 59, 0.28);
        }

        * { box-sizing: border-box; }

        html {
            scroll-behavior: smooth;
        }

        body {
            margin: 0;
            overflow-x: hidden;
            font-family: 'Roboto', sans-serif;
            background: var(--navy);
            color: var(--white);
        }

        h1, h2, h3, h4, h5 {
            font-family: 'Montserrat', sans-serif;
            letter-spacing: 0.3px;
        }

        .fw-900 { font-weight: 900; }

        .navbar {
            background: rgba(10, 20, 58, 0.94);
            backdrop-filter: blur(16px);
            min-height: 82px;
            border-bottom: 1px solid rgba(255,255,255,0.09);
        }

        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .brand-name {
            color: #fff !important;
            text-decoration: none;
            font-family: 'Montserrat', sans-serif;
            font-weight: 900;
            font-size: 16px;
            letter-spacing: 0.8px;
        }

        .header-logos {
            display: flex;
            align-items: center;
            gap: 12px;
            padding-left: 16px;
            border-left: 1px solid rgba(255,255,255,0.18);
        }

        .header-logos img {
    height: 50px; 
    width: auto;
}

        .nav-link {
            color: rgba(255,255,255,0.88) !important;
            font-weight: 700;
            font-size: 13px;
            text-transform: uppercase;
            margin-left: 18px;
            transition: 0.25s ease;
        }

        .nav-link:hover {
            color: #fff !important;
            opacity: 1;
        }

        .vote-chip {
            margin-left: 22px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #fff;
            color: var(--primary-blue);
            padding: 8px 16px;
            border-radius: 999px;
            font-weight: 900;
            font-size: 13px;
            text-transform: uppercase;
            text-decoration: none;
            box-shadow: 0 8px 22px rgba(0,0,0,0.18);
        }

        .vote-chip:hover {
            color: var(--deep-blue);
        }

        .social-nav {
            display: flex;
            gap: 14px;
            margin-left: 24px;
            padding-left: 18px;
            border-left: 1px solid rgba(255,255,255,0.18);
        }

        .social-nav a {
            color: rgba(255,255,255,0.82);
            font-size: 18px;
            transition: 0.25s ease;
        }

        .social-nav a:hover {
            color: #fff;
            transform: translateY(-2px);
        }

        .hero {
            min-height: 96vh;
            display: flex;
            align-items: center;
            position: relative;
            overflow: hidden;
            background:
                radial-gradient(circle at 75% 55%, rgba(255,255,255,0.12) 0, rgba(255,255,255,0.03) 18%, transparent 45%),
                linear-gradient(135deg, #0a143d 0%, #1d2d7d 45%, #3147b7 100%);
        }

        .hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background:
                radial-gradient(circle at 78% 70%, rgba(255,255,255,0.18) 0 2px, transparent 3px) 0 0/22px 22px,
                linear-gradient(90deg, rgba(0,0,0,0.28), rgba(0,0,0,0.02));
            opacity: 0.28;
            pointer-events: none;
        }

        .hero .container {
            position: relative;
            z-index: 2;
            padding-top: 110px;
            padding-bottom: 70px;
        }

        .hero-badges {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 22px;
        }

        .badge-soft {
            background: rgba(255,255,255,0.12);
            border: 1px solid rgba(255,255,255,0.15);
            color: #fff;
            padding: 10px 16px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .hero-title {
            font-size: clamp(2.3rem, 4.8vw, 4.8rem);
            font-weight: 900;
            line-height: 0.98;
            margin-bottom: 18px;
            text-transform: uppercase;
        }

        .hero-subtitle {
            font-size: clamp(1.4rem, 2.3vw, 2.1rem);
            color: var(--accent-light);
            margin-bottom: 16px;
            font-weight: 400;
        }

        .hero-lead {
            max-width: 660px;
            font-size: 1.12rem;
            line-height: 1.8;
            color: var(--text-soft);
            margin-bottom: 28px;
            padding-left: 18px;
            border-left: 3px solid rgba(255,255,255,0.7);
        }

        .vote-panel {
            display: flex;
            align-items: center;
            gap: 18px;
            flex-wrap: wrap;
            margin: 26px 0 30px;
        }

        .number-box {
            width: 140px;
            height: 140px;
            background: #fff;
            color: var(--secondary-blue);
            border-radius: 26px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 92px;
            font-family: 'Montserrat', sans-serif;
            font-weight: 900;
            box-shadow: var(--shadow);
        }

        .pref-circle {
            width: 140px;
            height: 140px;
            background: #fff;
            color: var(--secondary-blue);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 58px;
            font-family: 'Montserrat', sans-serif;
            font-weight: 900;
            box-shadow: var(--shadow);
        }

        .vote-copy {
            max-width: 300px;
        }

        .vote-copy h3 {
            font-size: 1.5rem;
            font-weight: 900;
            margin-bottom: 8px;
            text-transform: uppercase;
        }

        .vote-copy p {
            margin: 0;
            color: var(--text-soft);
            line-height: 1.65;
            font-size: 1rem;
        }

        .hero-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 14px;
            margin-top: 14px;
        }

        .btn-main {
            background: #fff;
            color: var(--primary-blue);
            border: none;
            border-radius: 999px;
            padding: 16px 32px;
            font-weight: 900;
            text-transform: uppercase;
            text-decoration: none;
            display: inline-block;
            transition: 0.25s ease;
        }

        .btn-main:hover {
            transform: translateY(-3px);
            color: var(--deep-blue);
            box-shadow: 0 14px 28px rgba(0,0,0,0.18);
        }

        .btn-outline-light {
            background: transparent;
            color: #fff;
            border: 2px solid rgba(255,255,255,0.55);
            border-radius: 999px;
            padding: 14px 30px;
            font-weight: 900;
            text-transform: uppercase;
            text-decoration: none;
            display: inline-block;
            transition: 0.25s ease;
        }

        .btn-outline-light:hover {
            background: #fff;
            color: var(--primary-blue);
        }

        .hero-image-wrap {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: flex-end;
            min-height: 100%;
        }

        .hero-image {
            max-width: 100%;
            width: 620px;
            height: auto;
            display: block;
            filter: drop-shadow(0 18px 35px rgba(0,0,0,0.35));
        }

        .logos-inline {
            display: flex;
            align-items: center;
            gap: 18px;
            margin-bottom: 30px;
        }

        .logos-inline img {
            height: 42px;
            width: auto;
        }

        .section-dark {
            background: #0c1743;
            padding: 72px 0;
        }

        .section-white {
            background: #fff;
            color: var(--text-dark);
            padding: 100px 0;
        }

        .section-soft {
            background: #eef3ff;
            color: var(--text-dark);
            padding: 100px 0;
        }

        .section-header {
            margin-bottom: 50px;
        }

        .section-header h2 {
            font-weight: 900;
            font-size: clamp(2rem, 3vw, 2.8rem);
            text-transform: uppercase;
            margin-bottom: 16px;
            color: inherit;
        }

        .section-header p {
            font-size: 1.08rem;
            line-height: 1.8;
            max-width: 860px;
            margin: 0;
            opacity: 0.88;
        }

        .trust-box {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 24px;
            padding: 38px;
        }

        .trust-box h2 {
            margin-bottom: 18px;
            font-weight: 900;
            text-transform: uppercase;
        }

        .trust-box p {
            margin: 0;
            color: var(--text-soft);
            line-height: 1.9;
            font-size: 1.08rem;
        }

        .priority-card {
            background: #fff;
            border-radius: 22px;
            padding: 36px;
            height: 100%;
            box-shadow: 0 16px 38px rgba(20, 36, 96, 0.08);
            border-bottom: 6px solid var(--secondary-blue);
        }

        .priority-card .icon {
            width: 68px;
            height: 68px;
            border-radius: 18px;
            background: #eef3ff;
            color: var(--secondary-blue);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            margin-bottom: 24px;
        }

        .priority-card h5 {
            font-size: 1.25rem;
            font-weight: 900;
            margin-bottom: 16px;
            text-transform: uppercase;
            color: var(--deep-blue);
        }

        .priority-card p {
            margin: 0;
            line-height: 1.85;
            color: #41507d;
        }

        .vote-banner {
            background: linear-gradient(135deg, #21348d 0%, #3147b7 100%);
            border-radius: 28px;
            padding: 42px;
            color: #fff;
            box-shadow: var(--shadow);
        }

        .vote-banner h3 {
            font-size: 2rem;
            font-weight: 900;
            text-transform: uppercase;
            margin-bottom: 14px;
        }

        .vote-banner p {
            color: rgba(255,255,255,0.9);
            line-height: 1.8;
            margin-bottom: 0;
        }

        .vote-banner .vote-panel {
            margin-bottom: 0;
        }

        .on-field-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            grid-auto-rows: 240px;
            gap: 16px;
        }

        .grid-item {
            position: relative;
            overflow: hidden;
            border-radius: 18px;
            box-shadow: 0 12px 26px rgba(20, 36, 96, 0.14);
            cursor: pointer;
        }

        .grid-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.45s ease, filter 0.45s ease;
        }

        .grid-item:hover img {
            transform: scale(1.08);
            filter: brightness(85%);
        }

        .grid-wide { grid-column: span 2; }
        .grid-tall { grid-row: span 2; }

        .media-section {
            background: #0b1438;
            padding: 100px 0;
        }

        .media-card {
            background: rgba(255,255,255,0.06);
            border-radius: 22px;
            padding: 36px;
            height: 100%;
            border-left: 5px solid #fff;
        }

        .media-card .source {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 18px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: var(--accent-light);
        }

        .media-card h4 {
            font-size: 1.5rem;
            line-height: 1.35;
            margin-bottom: 18px;
            font-weight: 800;
        }

        .media-card p {
            color: rgba(255,255,255,0.82);
            line-height: 1.8;
            margin-bottom: 22px;
        }

        .media-card .btn-outline-light {
            padding: 12px 22px;
            font-size: 13px;
        }

        .contact-wrap {
            background: linear-gradient(135deg, #1b2f86 0%, #2e43ae 100%);
            padding: 110px 0;
        }

        .contact-card {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 24px;
            padding: 40px;
        }

        .form-control {
            background: rgba(255,255,255,0.14);
            border: 1px solid rgba(255,255,255,0.18);
            color: #fff !important;
            padding: 16px;
            border-radius: 14px;
        }

        .form-control::placeholder {
            color: rgba(255,255,255,0.7) !important;
        }

        .form-control:focus {
            background: rgba(255,255,255,0.18);
            border-color: rgba(255,255,255,0.35);
            color: #fff;
            box-shadow: none;
        }

        .final-section {
            background: #08122f;
            padding: 85px 0;
        }

        footer {
            background: #050b1c;
            padding: 48px 0;
            text-align: center;
            color: rgba(255,255,255,0.72);
            font-size: 14px;
        }

        @media (max-width: 991px) {
            .header-logos, .social-nav { display: none; }
            .vote-chip { margin-left: 0; margin-top: 12px; }
            .navbar-collapse { padding-top: 16px; }

            .hero {
                text-align: center;
            }

            .logos-inline {
                justify-content: center;
            }

            .hero-lead {
                margin-inline: auto;
                padding-left: 0;
                border-left: none;
                border-top: 3px solid rgba(255,255,255,0.7);
                padding-top: 18px;
            }

            .hero-badges,
            .hero-actions,
            .vote-panel {
                justify-content: center;
            }

            .vote-copy {
                max-width: 100%;
            }

            .hero-image {
                width: 440px;
                margin-top: 30px;
            }

            .grid-wide { grid-column: span 1; }
            .on-field-grid { grid-auto-rows: 210px; }
        }

        @media (max-width: 575px) {
            .hero .container {
                padding-top: 105px;
                padding-bottom: 50px;
            }

            .number-box,
            .pref-circle {
                width: 112px;
                height: 112px;
            }

            .number-box { font-size: 74px; }
            .pref-circle { font-size: 42px; }

            .vote-banner,
            .contact-card,
            .trust-box,
            .priority-card,
            .media-card {
                padding: 28px;
            }

            .btn-main,
            .btn-outline-light {
                width: 100%;
                text-align: center;
            }
        }
    </style>
</head>
